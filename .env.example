# Copy to .env and fill in. .env is gitignored — never commit it.

# Required from Stage 4 onward (LLM propose/analyze nodes)
GROQ_API_KEY=

# Optional — tracing. If unset, tracing is a no-op (logged once at startup).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Postgres connections.
# PG_ADMIN_DSN: superuser, used ONLY by load_data.py to bootstrap.
# PG_AGENT_DSN: queryforge_agent — the role the oracle and LLM DDL run as.
PG_ADMIN_DSN=postgresql://postgres:postgres@localhost:5432/queryforge
PG_AGENT_DSN=postgresql://queryforge_agent:agentpw@localhost:5432/queryforge
